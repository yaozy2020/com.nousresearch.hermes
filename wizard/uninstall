[{
  "stepTitle": "卸载 Hermes",
  "items": [
    {
      "type": "tips",
      "helpText": "你可以选择保留配置文件和运行环境，方便下次重装时快速恢复。"
    },
    {
      "type": "switch",
      "field": "wizard_keep_config",
      "label": "保留配置文件",
      "initValue": "true",
      "helpText": "保留 config.yaml、.env、SOUL.md 等配置，避免误卸载后重新设置。"
    },
    {
      "type": "switch",
      "field": "wizard_keep_runtime",
      "label": "保留运行环境",
      "initValue": "true",
      "helpText": "保留 venv、已下载模型、运行时状态与日志，避免误卸载后重新下载。"
    },
    {
      "type": "switch",
      "field": "wizard_confirm_uninstall",
      "label": "我已了解风险，确认卸载",
      "initValue": "false"
    }
  ]
}]
