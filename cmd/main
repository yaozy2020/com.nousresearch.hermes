#!/bin/bash

# Hermes FPK — main lifecycle script
# Manages the Bun-based control panel server via Unix socket

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"

# Bun / Node path
# 优先使用用户家目录下的 bun（v1.3.14 通过官方脚本安装），其次飞牛应用中心 bunjs
export PATH="$HOME/.bun/bin:/var/apps/bunjs/target/bin:/var/apps/nodejs_v24/target/bin:$PATH"

# fnOS service 默认 LANG 为空，bun 在空 locale 下会把 utf-8 源文件按 latin-1 解码，
# 导致中文字面量 "运行时" 变成 3 个 0x80~0xFF char，最终 JSON 响应里输出 \u00e8\u00bf\u0090
# 而前端 fnOS App WebView 渲染就是经典的 utf-8 当 latin-1 显示乱码（"Bun è¿è¡æ¶"）。
# 强制 utf-8 locale 让 bun 正确解码源文件。
export LANG=C.UTF-8
export LC_ALL=C.UTF-8

# Data directory (@apphome)
HERMES_DATA_DIR="${TRIM_PKGHOME}/data"

# Server binary (bundled in app.tgz → TRIM_APPDEST/server/)
SERVER_SCRIPT="${TRIM_APPDEST}/server/index.js"

# Static frontend files
STATIC_DIR="${TRIM_APPDEST}/ui"

# ttyd binary dir (v0.20.4)
HERMES_PANEL_BIN="${TRIM_APPDEST}/bin"

# Unix socket for fnOS gateway
SOCKET_PATH="${TRIM_APPDEST}/com.nousresearch.hermes.sock"

# Hermes venv (Python runtime for gateway)
HERMES_VENV="${HERMES_DATA_DIR}/venv"
HERMES_BIN="${HERMES_VENV}/bin/hermes"
HERMES_HOME="${HERMES_DATA_DIR}/home"

# 加载用户在安装向导中设置的端口等环境变量
if [ -f "${HERMES_HOME}/.env" ]; then
    set -a
    . "${HERMES_HOME}/.env"
    set +a
fi

# 导出给 server/index.js 的环境变量
export HERMES_DATA_DIR="${HERMES_DATA_DIR}"
export STATIC_DIR="${STATIC_DIR}"
export SOCKET_PATH="${SOCKET_PATH}"
export HERMES_VENV="${HERMES_VENV}"
export HERMES_BIN="${HERMES_BIN}"
export HERMES_PANEL_BIN="${HERMES_PANEL_BIN}"
export HERMES_DASHBOARD_PORT="${HERMES_DASHBOARD_PORT:-9119}"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

start_process() {
    if status; then
        return 0
    fi

    if ! command -v bun >/dev/null 2>&1; then
        log_msg "bun command not found in PATH"
        return 1
    fi

    log_msg "Starting Hermes control panel ..."
    rm -f "${SOCKET_PATH}"
    # 直接启动 bun，记录的就是 bun 进程 PID，避免 bash 子进程残留
    bun "${SERVER_SCRIPT}" >> ${LOG_FILE} 2>&1 &
    printf "%s" "$!" > ${PID_FILE}
    log_msg "Started, pid=$!"
    return 0
}

stop_process() {
    log_msg "Stopping Hermes control panel ..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        log_msg "pid=${pid}"

        if ! check_process "${pid}"; then
            rm -f "${PID_FILE}"
            log_msg "process already dead, removed pid file"
            return 0
        fi

        log_msg "send TERM signal to PID:${pid}..."
        kill -TERM ${pid} >> ${LOG_FILE} 2>&1

        local count=0
        while check_process "${pid}" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
        done

        if check_process "${pid}"; then
            log_msg "send KILL signal to PID:${pid}..."
            kill -KILL "${pid}"
            sleep 1
            rm -f "${PID_FILE}"
        else
            log_msg "process terminated"
        fi
    fi

    # Also stop Hermes gateway if running
    if [ -x "${HERMES_BIN}" ]; then
        "${HERMES_BIN}" gateway stop >> ${LOG_FILE} 2>&1 || true
        "${HERMES_BIN}" dashboard --stop >> ${LOG_FILE} 2>&1 || true
    fi

    # Also stop ttyd if running (v0.20.4)
    if [ -r "${HERMES_DATA_DIR}/runtime/ttyd.pid" ]; then
        ttyd_pid=$(head -n 1 "${HERMES_DATA_DIR}/runtime/ttyd.pid" | tr -d '[:space:]')
        if [ -n "${ttyd_pid}" ]; then
            kill -TERM "${ttyd_pid}" 2>/dev/null || true
            rm -f "${HERMES_DATA_DIR}/runtime/ttyd.pid"
        fi
    fi
    pkill -f "${HERMES_PANEL_BIN}/ttyd" 2>/dev/null || true

    rm -f "${SOCKET_PATH}"
    return 0
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi
    return 1
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
restart)
    stop_process
    sleep 1
    start_process
    ;;
*)
    echo "Usage: $0 {start|stop|status|restart}"
    exit 1
    ;;
esac
