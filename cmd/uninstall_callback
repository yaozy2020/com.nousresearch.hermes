#!/bin/bash

### uninstall_callback — 处理 wizard 卸载选择，按需删除数据
### wizard_delete_data: "true" → 删除全部数据；"false" / 其他 → 保留
### 不论选哪种，瞬态 socket / pid / 临时目录都会被清掉

LOG_FILE="${TRIM_PKGVAR:-/tmp}/uninstall.log"
log() { echo "$(date '+%F %T') $*" >> "$LOG_FILE"; }

log "=== uninstall_callback start ==="
log "wizard_delete_data=${wizard_delete_data:-<unset>}"

DATA_DIR="${TRIM_PKGHOME}/data"
APP_DIR="${TRIM_APPDEST}"

# 0) 兜底：socket / pid 一律清理
rm -f "${APP_DIR}/com.nousresearch.hermes.sock" 2>/dev/null
rm -f "${APP_DIR}"/*.sock 2>/dev/null
rm -f "${DATA_DIR}/runtime/"*.pid 2>/dev/null

# 1) 用户选择保留 → 直接退出
if [ "${wizard_delete_data}" != "true" ]; then
    log "User chose to keep data, leaving DATA_DIR untouched: ${DATA_DIR}"
    log "=== uninstall_callback done (data kept) ==="
    exit 0
fi

# 2) 用户选择清除 → 完整删除
log "User chose to delete ALL data, wiping ${DATA_DIR} ..."

if [ -d "$DATA_DIR" ]; then
    # 列出磁盘占用，便于事后核对
    DU=$(du -sh "$DATA_DIR" 2>/dev/null | awk '{print $1}')
    log "Data dir size before delete: $DU"

    # 逐个子目录删除（更稳，避免一次 rm -rf 整个 home 误伤）
    for SUB in venv .hermes home config logs workspace runtime state install; do
        TARGET="${DATA_DIR}/${SUB}"
        if [ -e "$TARGET" ]; then
            log "  removing ${TARGET} ..."
            rm -rf "$TARGET" 2>/dev/null || log "    failed to remove ${TARGET}"
        fi
    done

    # 删除任何残留的隐藏配置（.env / .hermes_*）
    rm -rf "${DATA_DIR}"/.env 2>/dev/null
    rm -rf "${DATA_DIR}"/.hermes_* 2>/dev/null

    # 最后尝试删空 data 目录本身
    rmdir "$DATA_DIR" 2>/dev/null || log "DATA_DIR not empty, leaving for fnOS to clean"
fi

log "=== uninstall_callback done (data wiped) ==="
exit 0
